<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<!--
    Fluent 2 Styles — SyncoStronbo
    Source: https://fluent2.microsoft.design
    See docs/fluent2-style-guide.md for design token rationale.

    Implicit styles (no x:Key) apply to every matching element.
    Named styles (x:Key="...") must be applied explicitly and map to the
    Fluent 2 type ramp and component variants.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         TYPOGRAPHY — Named styles for the Fluent 2 type ramp
         source: fluent2.microsoft.design/typography
         Font: platform default (Roboto on Android, SF Pro on iOS).
         FontFamily is intentionally NOT set → falls back to the
         native system font per Fluent 2 "Natural on every platform".
         Bold maps to Semibold roles (MAUI has no Semibold weight).
    ═══════════════════════════════════════════════════════════ -->

    <!-- Caption 2  |  Regular  |  10 / 14 -->
    <Style x:Key="Caption2" TargetType="Label">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="LineHeight" Value="1.4"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral90}, Dark={StaticResource DarkTextSecondary}}"/>
    </Style>

    <!-- Caption 1  |  Regular  |  12 / 16 -->
    <Style x:Key="Caption1" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="LineHeight" Value="1.33"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral90}, Dark={StaticResource DarkTextSecondary}}"/>
    </Style>

    <!-- Caption 1 Strong  |  Bold  |  12 / 16 -->
    <Style x:Key="Caption1Strong" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="LineHeight" Value="1.33"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
    </Style>

    <!-- Body 1  |  Regular  |  14 / 20  (= implicit Label default) -->
    <Style x:Key="Body1" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="LineHeight" Value="1.43"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
    </Style>

    <!-- Body 1 Strong  |  Bold  |  14 / 20 -->
    <Style x:Key="Body1Strong" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="LineHeight" Value="1.43"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
    </Style>

    <!-- Subtitle 2  |  Bold  |  16 / 22 -->
    <Style x:Key="Subtitle2" TargetType="Label">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="LineHeight" Value="1.375"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
    </Style>

    <!-- Subtitle 1  |  Bold  |  20 / 28 -->
    <Style x:Key="Subtitle1" TargetType="Label">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="LineHeight" Value="1.4"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral110}, Dark={StaticResource DarkTextPrimary}}"/>
    </Style>

    <!-- Title 3  |  Bold  |  24 / 32 -->
    <Style x:Key="Title3" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="LineHeight" Value="1.33"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral110}, Dark={StaticResource DarkTextPrimary}}"/>
    </Style>

    <!-- Title 2  |  Bold  |  28 / 36 -->
    <Style x:Key="Title2" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="LineHeight" Value="1.29"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral110}, Dark={StaticResource DarkTextPrimary}}"/>
    </Style>

    <!-- Title 1  |  Bold  |  32 / 40 -->
    <Style x:Key="Title1" TargetType="Label">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="LineHeight" Value="1.25"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral110}, Dark={StaticResource DarkTextPrimary}}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         NAMED COMPONENT STYLES
    ═══════════════════════════════════════════════════════════ -->

    <!--
        FluentCard — elevated surface ($shadow4 equivalent).
        source: fluent2.microsoft.design/elevation  $shadow4
                fluent2.microsoft.design/shapes     X-Large (12px)
        Use: wrap content in a Border with Style="{StaticResource FluentCard}"
    -->
    <Style x:Key="FluentCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Neutral20}, Dark={StaticResource DarkSurface}}"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <!-- $shadow4: Y=2, Blur=4, Opacity=14% on light / 28% on dark -->
                <Shadow Brush="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource Black}}"
                        Offset="0,2"
                        Radius="4"
                        Opacity="{AppThemeBinding Light=0.14, Dark=0.28}"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        BrandButton — filled brand button (primary CTA).
        source: fluent2.microsoft.design/shapes §Corner radius Medium=4px
    -->
    <Style x:Key="BrandButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimary}"/>
        <Setter Property="TextColor" Value="{StaticResource White}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest" Value="48"/>
    </Style>

    <!--
        SubtleButton — low-emphasis action button (neutral fill).
    -->
    <Style x:Key="SubtleButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Neutral30}, Dark={StaticResource DarkSurfaceRaised}}"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest" Value="48"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         IMPLICIT STYLES  (apply globally, no x:Key)
    ═══════════════════════════════════════════════════════════ -->

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
    </Style>

    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor"         Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
        <Setter Property="SelectedIndicatorColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
    </Style>

    <!--
        Border — default thin stroke.
        source: fluent2.microsoft.design/shapes §Stroke Thin=1px
    -->
    <Style TargetType="Border">
        <Setter Property="Stroke"          Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
        <Setter Property="StrokeShape"     Value="Rectangle"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
    </Style>

    <!--
        Button — default implicit style.
        Corner radius: Large=8px per Fluent shapes (large controls).
        Touch target: 48dp (Android Fluent 2 recommendation).
    -->
    <Style TargetType="Button">
        <Setter Property="TextColor"            Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}"/>
        <Setter Property="BackgroundColor"      Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandPrimary}}"/>
        <Setter Property="FontSize"             Value="14"/>
        <Setter Property="CornerRadius"         Value="8"/>
        <Setter Property="Padding"              Value="16,0"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor"       Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Neutral40}, Dark={StaticResource DarkSurface}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color"                Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor"            Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="BackgroundColor"      Value="Transparent"/>
        <Setter Property="FontSize"             Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor"            Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="BackgroundColor"      Value="Transparent"/>
        <Setter Property="FontSize"             Value="14"/>
        <Setter Property="PlaceholderColor"     Value="{AppThemeBinding Light={StaticResource Neutral80}, Dark={StaticResource DarkPlaceholder}}"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor"            Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="BackgroundColor"      Value="Transparent"/>
        <Setter Property="FontSize"             Value="14"/>
        <Setter Property="PlaceholderColor"     Value="{AppThemeBinding Light={StaticResource Neutral80}, Dark={StaticResource DarkPlaceholder}}"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--
        Frame — legacy container; use Border + FluentCard style when possible.
        Corner radius: X-Large=12px (cards/large containers).
    -->
    <Style TargetType="Frame">
        <Setter Property="HasShadow"    Value="False"/>
        <Setter Property="BorderColor"  Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <Style TargetType="ImageButton">
        <Setter Property="Opacity"              Value="1"/>
        <Setter Property="BorderColor"          Value="Transparent"/>
        <Setter Property="BorderWidth"          Value="0"/>
        <Setter Property="CornerRadius"         Value="0"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.4"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--
        Label — default = Body 1 (14 / 20, Regular).
        source: fluent2.microsoft.design/typography §Body 1
    -->
    <Style TargetType="Label">
        <Setter Property="TextColor"       Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontSize"        Value="14"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="ListView">
        <Setter Property="SeparatorColor"     Value="{AppThemeBinding Light={StaticResource Neutral40}, Dark={StaticResource DarkBorder}}"/>
        <Setter Property="RefreshControlColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor"            Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="TitleColor"           Value="{AppThemeBinding Light={StaticResource Neutral80}, Dark={StaticResource DarkPlaceholder}}"/>
        <Setter Property="BackgroundColor"      Value="Transparent"/>
        <Setter Property="FontSize"             Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor"  Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                            <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="ProgressColor" Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="BackgroundColor"      Value="Transparent"/>
        <Setter Property="TextColor"            Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="FontSize"             Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor"            Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="PlaceholderColor"     Value="{AppThemeBinding Light={StaticResource Neutral80}, Dark={StaticResource DarkPlaceholder}}"/>
        <Setter Property="CancelButtonColor"    Value="{StaticResource BrandPrimary}"/>
        <Setter Property="BackgroundColor"      Value="Transparent"/>
        <Setter Property="FontSize"             Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor"        Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                            <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="SearchHandler">
        <Setter Property="TextColor"        Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Neutral80}, Dark={StaticResource DarkPlaceholder}}"/>
        <Setter Property="BackgroundColor"  Value="Transparent"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor"        Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                            <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--
        Shadow — default = $shadow4 equivalent.
        source: fluent2.microsoft.design/elevation §Low elevation ramp
        $shadow4: cards, grid items, list items.
        Y=2, Blur=4, Opacity 14% light / 28% dark.
    -->
    <Style TargetType="Shadow">
        <Setter Property="Brush"   Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource Black}}"/>
        <Setter Property="Offset"  Value="0,2"/>
        <Setter Property="Radius"  Value="4"/>
        <Setter Property="Opacity" Value="{AppThemeBinding Light=0.14, Dark=0.28}"/>
    </Style>

    <!--
        Slider — brand-coloured track.
    -->
    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
        <Setter Property="MaximumTrackColor" Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
        <Setter Property="ThumbColor"        Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="MinimumTrackColor" Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
                            <Setter Property="MaximumTrackColor" Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
                            <Setter Property="ThumbColor"        Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="SwipeItem">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Neutral20}, Dark={StaticResource DarkSurface}}"/>
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor"    Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
        <Setter Property="ThumbColor" Value="{StaticResource White}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="OnColor"    Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="On">
                        <VisualState.Setters>
                            <Setter Property="OnColor"    Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
                            <Setter Property="ThumbColor" Value="{StaticResource White}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Off">
                        <VisualState.Setters>
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextSecondary}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="TextColor"            Value="{AppThemeBinding Light={StaticResource Neutral100}, Dark={StaticResource DarkTextPrimary}}"/>
        <Setter Property="BackgroundColor"      Value="Transparent"/>
        <Setter Property="FontSize"             Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="48"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Neutral70}, Dark={StaticResource DarkTextDisabled}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--
        Page — Fluent 2 app background.
        Light: Neutral10 (#FAF9F8) — warm off-white, not pure white.
        Dark:  DarkBackground (#1C1C1C) — dark warm grey.
        source: fluent2.microsoft.design/color §Neutral colors
    -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="BackgroundColor"  Value="{AppThemeBinding Light={StaticResource Neutral10}, Dark={StaticResource DarkBackground}}"/>
    </Style>

    <!--
        Shell — navbar uses BrandPrimary (#0078D4) on light,
        dark surface on dark mode.
        source: fluent2.microsoft.design/color §Brand colors
    -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor"      Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource DarkBackground}}"/>
        <Setter Property="Shell.ForegroundColor"      Value="{StaticResource White}"/>
        <Setter Property="Shell.TitleColor"           Value="{StaticResource White}"/>
        <Setter Property="Shell.DisabledColor"        Value="{AppThemeBinding Light={StaticResource BrandTint40}, Dark={StaticResource DarkTextDisabled}}"/>
        <Setter Property="Shell.UnselectedColor"      Value="{AppThemeBinding Light={StaticResource BrandTint20}, Dark={StaticResource DarkTextSecondary}}"/>
        <Setter Property="Shell.NavBarHasShadow"      Value="False"/>
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource DarkBackground}}"/>
        <Setter Property="Shell.TabBarForegroundColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
        <Setter Property="Shell.TabBarTitleColor"      Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource Neutral90}, Dark={StaticResource DarkTextSecondary}}"/>
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource DarkBackground}}"/>
        <Setter Property="BarTextColor"       Value="{StaticResource White}"/>
        <Setter Property="IconColor"          Value="{StaticResource White}"/>
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor"   Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource DarkBackground}}"/>
        <Setter Property="BarTextColor"         Value="{AppThemeBinding Light={StaticResource BrandPrimary}, Dark={StaticResource BrandTint20}}"/>
        <Setter Property="UnselectedTabColor"   Value="{AppThemeBinding Light={StaticResource Neutral50}, Dark={StaticResource DarkBorder}}"/>
