<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<!--
    Fluent 2 Color Tokens — SyncoStronbo
    Source: https://fluent2.microsoft.design/color
    See docs/fluent2-style-guide.md for the full token rationale.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         BRAND PALETTE  (Communication Blue — Microsoft / Fluent 2)
         source: fluent2.microsoft.design/color § Brand colors
    ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="BrandPrimary">#0078D4</Color>     <!-- rest state: buttons, links, selected -->
    <Color x:Key="BrandHover">#106EBE</Color>       <!-- hover/focus state -->
    <Color x:Key="BrandPressed">#005A9E</Color>     <!-- pressed / active state -->
    <Color x:Key="BrandTint10">#2B88D8</Color>      <!-- light tint, icon fills -->
    <Color x:Key="BrandTint20">#69AFE5</Color>      <!-- lighter tint -->
    <Color x:Key="BrandTint40">#A9D3F0</Color>      <!-- disabled accent fill -->
    <Color x:Key="BrandBackground">#EFF6FC</Color>  <!-- brand-tinted surface (light mode) -->
    <Color x:Key="BrandBackgroundDark">#004578</Color> <!-- brand-tinted surface (dark mode) -->

    <!-- ═══════════════════════════════════════════════════════════════
         NEUTRAL PALETTE  (light mode)
         source: fluent2.microsoft.design/color § Neutral colors
         Fluent neutrals are warm-shifted greys (#FAF9F8 … #000000).
         Lighter neutrals = higher visual hierarchy (more focus).
    ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Neutral10">#FAF9F8</Color>   <!-- page / app background -->
    <Color x:Key="Neutral20">#F3F2F1</Color>   <!-- card / elevated surface -->
    <Color x:Key="Neutral30">#EDEBE9</Color>   <!-- hover surface -->
    <Color x:Key="Neutral40">#E1DFDD</Color>   <!-- subtle border / divider -->
    <Color x:Key="Neutral50">#D2D0CE</Color>   <!-- border -->
    <Color x:Key="Neutral60">#C8C6C4</Color>   <!-- strong border -->
    <Color x:Key="Neutral70">#B3B0AD</Color>   <!-- disabled icon / placeholder -->
    <Color x:Key="Neutral80">#8A8886</Color>   <!-- placeholder text -->
    <Color x:Key="Neutral90">#605E5C</Color>   <!-- secondary / caption text -->
    <Color x:Key="Neutral100">#323130</Color>  <!-- primary body text -->
    <Color x:Key="Neutral110">#201F1E</Color>  <!-- strong heading text -->
    <Color x:Key="Black">#000000</Color>

    <!-- ═══════════════════════════════════════════════════════════════
         NEUTRAL PALETTE  (dark mode surfaces)
    ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="DarkBackground">#1C1C1C</Color>       <!-- page / app background -->
    <Color x:Key="DarkSurface">#2D2D2D</Color>          <!-- card / elevated surface -->
    <Color x:Key="DarkSurfaceRaised">#383838</Color>    <!-- raised / active surface -->
    <Color x:Key="DarkBorder">#404040</Color>           <!-- border -->
    <Color x:Key="DarkBorderStrong">#525252</Color>     <!-- strong border / divider -->
    <Color x:Key="DarkTextPrimary">#FFFFFF</Color>      <!-- primary body text -->
    <Color x:Key="DarkTextSecondary">#B3B0AD</Color>    <!-- secondary / caption text -->
    <Color x:Key="DarkTextDisabled">#605E5C</Color>     <!-- disabled text -->
    <Color x:Key="DarkPlaceholder">#8A8886</Color>      <!-- placeholder text -->

    <!-- ═══════════════════════════════════════════════════════════════
         SEMANTIC PALETTE
         source: fluent2.microsoft.design/color § Semantic Colors
         Use ONLY to convey status/urgency. Never decoratively.
         Pair with text/icons — never rely on color alone (accessibility).
    ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="SemanticSuccess">#107C10</Color>
    <Color x:Key="SemanticSuccessBg">#DFF6DD</Color>
    <Color x:Key="SemanticWarning">#FFB900</Color>
    <Color x:Key="SemanticWarningBg">#FFF4CE</Color>
    <Color x:Key="SemanticDanger">#D13438</Color>
    <Color x:Key="SemanticDangerBg">#FDE7E9</Color>
    <Color x:Key="SemanticInfo">#0078D4</Color>    <!-- same as BrandPrimary -->
    <Color x:Key="SemanticInfoBg">#EFF6FC</Color>  <!-- same as BrandBackground -->

    <!-- ═══════════════════════════════════════════════════════════════
         PAD PALETTE  — pastel tones for device pads on dark backgrounds
         Soft values (70-80% brightness, ~50-60% saturation) read as
         "pastel" against the #1C1C1C DarkBackground.
    ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="PadCoral">#F28B82</Color>
    <Color x:Key="PadPeach">#F4A261</Color>
    <Color x:Key="PadGold">#E9C46A</Color>
    <Color x:Key="PadMint">#80C9A4</Color>
    <Color x:Key="PadSky">#74C2E1</Color>
    <Color x:Key="PadPeriwinkle">#8AB4F8</Color>
    <Color x:Key="PadLavender">#C58AF9</Color>
    <Color x:Key="PadPink">#F48FB1</Color>
    <Color x:Key="PadTeal">#7DCFBF</Color>
    <Color x:Key="PadMelon">#F4B183</Color>
    <Color x:Key="PadSage">#A8D8A8</Color>
    <Color x:Key="PadWheat">#E0C89A</Color>
    <Color x:Key="PadPowderBlue">#90C8E8</Color>
    <Color x:Key="PadDustyRose">#D4A0A8</Color>
    <Color x:Key="PadMintSage">#A8D0B8</Color>
    <Color x:Key="PadSlate">#A0B8D8</Color>

    <!-- ═══════════════════════════════════════════════════════════════
         BACKWARD-COMPATIBLE ALIASES
         Old key names kept so existing XAML pages compile unchanged.
         Values now point to Fluent 2 equivalents.
    ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="Primary">#0078D4</Color>        <!-- → BrandPrimary -->
    <Color x:Key="Secondary">#EFF6FC</Color>      <!-- → BrandBackground -->
    <Color x:Key="Tertiary">#005A9E</Color>       <!-- → BrandPressed -->

    <Color x:Key="Gray100">#F3F2F1</Color>        <!-- → Neutral20 (card surface) -->
    <Color x:Key="Gray200">#E1DFDD</Color>        <!-- → Neutral40 (subtle border) -->
    <Color x:Key="Gray300">#D2D0CE</Color>        <!-- → Neutral50 (border) -->
    <Color x:Key="Gray400">#B3B0AD</Color>        <!-- → Neutral70 (disabled) -->
    <Color x:Key="Gray500">#8A8886</Color>        <!-- → Neutral80 (placeholder) -->
    <Color x:Key="Gray600">#605E5C</Color>        <!-- → Neutral90 (secondary text) -->
    <Color x:Key="Gray900">#323130</Color>        <!-- → Neutral100 (primary text) -->
    <Color x:Key="Gray950">#1C1C1C</Color>        <!-- → DarkBackground -->

    <!-- ── SolidColorBrush mirrors ──────────────────────────────── -->
    <SolidColorBrush x:Key="PrimaryBrush"     Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush"   Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush"    Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush"       Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"       Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush"     Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"     Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"     Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"     Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"     Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"     Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"     Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"     Color="{StaticResource Gray950}"/>
    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimary}"/>

</ResourceDictionary>