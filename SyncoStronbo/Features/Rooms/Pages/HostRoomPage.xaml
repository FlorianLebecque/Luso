<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SyncoStronbo.Features.Rooms.Pages.HostRoomPage"
             Title="Host Room">

    <!-- Navbar actions -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="＋" Priority="0" Clicked="OnInviteToolbarClicked"/>
        <ToolbarItem Text="Kick" Priority="1" Clicked="OnKickToolbarClicked"/>
        <ToolbarItem Text="✕ Close" Priority="2" Clicked="OnLeaveClicked"/>
    </ContentPage.ToolbarItems>

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" IsEnabled="False"/>
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,Auto,Auto,*"
          Padding="12,8,12,12"
          RowSpacing="10">

        <!-- Room name -->
        <Label x:Name="lblRoomName"
               Grid.Row="0"
               FontSize="22" FontAttributes="Bold"
               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>


        <!-- Mode selector: Off | On | Auto -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
            <Button x:Name="btnModeOff"
                    Grid.Column="0" Text="Off"
                    Clicked="OnModeClicked"
                    BackgroundColor="#444" TextColor="White"
                    HeightRequest="40" CornerRadius="8"/>
            <Button x:Name="btnModeOn"
                    Grid.Column="1" Text="On"
                    Clicked="OnModeClicked"
                    BackgroundColor="#444" TextColor="White"
                    HeightRequest="40" CornerRadius="8"/>
            <Button x:Name="btnModeAuto"
                    Grid.Column="2" Text="Auto"
                    Clicked="OnModeClicked"
                    BackgroundColor="#444" TextColor="White"
                    HeightRequest="40" CornerRadius="8"/>
        </Grid>

        <!-- Frequency panel - visible in On mode only -->
        <VerticalStackLayout x:Name="sliderPanel"
                             Grid.Row="2"
                             IsVisible="False"
                             Spacing="2">
            <Label x:Name="lblFrequency"
                   Text="Frequency: 1.0 Hz"
                   HorizontalOptions="Center"
                   FontSize="12" TextColor="Gray"/>
            <Slider x:Name="frequencySlider"
                    Minimum="0.5" Maximum="20" Value="1"
                    ValueChanged="OnFrequencyChanged"/>
        </VerticalStackLayout>

        <!-- Dynamic pad grid: host first, then one pad per connected guest -->
        <Grid x:Name="padGrid" Grid.Row="3" RowSpacing="8" ColumnSpacing="8"/>
    </Grid>
</ContentPage>
