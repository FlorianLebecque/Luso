<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SyncoStronbo.Features.Rooms.Pages.BrowseRoomsPage"
             Title="Join a Room">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">
        <HorizontalStackLayout Grid.Row="0" Spacing="10" VerticalOptions="Center">
            <ActivityIndicator x:Name="spinner" IsRunning="True" WidthRequest="24" HeightRequest="24" VerticalOptions="Center"/>
            <Label x:Name="lblStatus" Text="Scanning for rooms on this network…" VerticalOptions="Center"/>
        </HorizontalStackLayout>

        <CollectionView x:Name="roomsCollection" Grid.Row="1" SelectionMode="Single" SelectionChanged="OnRoomSelected">
            <CollectionView.EmptyView>
                <Label Text="No rooms found yet." HorizontalOptions="Center" VerticalOptions="Center" TextColor="Gray" Margin="0,40,0,0"/>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,16" ColumnDefinitions="*,Auto" BackgroundColor="Transparent">
                        <Label Grid.Column="0" Text="{Binding RoomName}" FontSize="Large" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding HostIp}" FontSize="Small" TextColor="Gray" VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" Text="Cancel" Clicked="OnCancelClicked" BackgroundColor="Gray"/>
    </Grid>
</ContentPage>
