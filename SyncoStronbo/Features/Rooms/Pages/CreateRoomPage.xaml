<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SyncoStronbo.Features.Rooms.Pages.CreateRoomPage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- Header: back button + title -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*"
              Padding="8,48,16,0">
            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="28"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource DarkTextSecondary}"
                    WidthRequest="48" HeightRequest="48"
                    Padding="0"
                    Clicked="OnBackClicked"/>
            <Label Grid.Column="1"
                   Text="New Room"
                   Style="{StaticResource Title2}"
                   VerticalOptions="Center"
                   Margin="4,0,0,0"/>
        </Grid>

        <!-- Form -->
        <VerticalStackLayout Grid.Row="1" Spacing="0" Padding="24,20,24,24">

            <Label Text="Choose a name for your sync session"
                   Style="{StaticResource Caption1}"
                   TextColor="{StaticResource DarkTextSecondary}"
                   Margin="0,0,0,32"/>

        <!-- Entry card -->
        <Border BackgroundColor="{StaticResource DarkSurface}"
                StrokeThickness="1"
                Stroke="{StaticResource DarkBorder}"
                StrokeShape="RoundRectangle 12"
                Padding="4,0"
                Margin="0,0,0,16">
            <Entry x:Name="entryName"
                   Placeholder="e.g. Party Lights"
                   MaxLength="30"
                   BackgroundColor="Transparent"
                   TextColor="White"
                   PlaceholderColor="{StaticResource DarkTextDisabled}"
                   Margin="8,0"
                   ClearButtonVisibility="WhileEditing"/>
        </Border>

        <Button x:Name="btnCreate"
                Text="Create &amp; Start"
                Clicked="OnCreateClicked"
                BackgroundColor="{StaticResource BrandPrimary}"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="12"
                HeightRequest="52"
                Margin="0,0,0,16"/>

        <ActivityIndicator x:Name="spinner"
                           IsRunning="False"
                           IsVisible="False"
                           HorizontalOptions="Center"/>

        <Label x:Name="lblError"
               TextColor="{StaticResource SemanticDanger}"
               IsVisible="False"
               HorizontalOptions="Center"
               Margin="0,8,0,0"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
