<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SyncoStronbo.Pages.GuestRoomPage"
             Title="Guest Room">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" IsEnabled="False"/>
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="*,Auto" Padding="24" RowSpacing="16">

        <VerticalStackLayout Grid.Row="0" Spacing="18"
                             VerticalOptions="Center" HorizontalOptions="Center">

            <Label x:Name="lblRoomName"
                   FontSize="36" FontAttributes="Bold"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

            <Label Text="You are connected as Guest"
                   FontSize="Medium" TextColor="Gray"
                   HorizontalOptions="Center"/>

            <Label x:Name="lblHost"
                   FontSize="Medium"
                   HorizontalOptions="Center"/>

            <Label x:Name="lblStatus"
                   Text="Connected to host"
                   FontSize="Medium"
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>

        <Button Grid.Row="1" Text="Leave Room" Clicked="OnLeaveClicked"
                BackgroundColor="#E74C3C" TextColor="White" HeightRequest="50"/>

    </Grid>
</ContentPage>
