<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SyncoStronbo.Pages.RoomPage"
             Title="Room">

    <!-- Disable the hardware back button so the user must press Leave -->
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" IsEnabled="False"/>
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="*,Auto" Padding="24" RowSpacing="16">

        <VerticalStackLayout Grid.Row="0" Spacing="18"
                             VerticalOptions="Center" HorizontalOptions="Fill">

            <Label x:Name="lblRoomName"
                   FontSize="36" FontAttributes="Bold"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

            <Label x:Name="lblRole"
                   FontSize="Medium" TextColor="Gray"
                   HorizontalOptions="Center"/>

            <!-- Guest view: simple status label -->
            <Label x:Name="lblGuestStatus"
                   Text="Connected to host"
                   FontSize="Medium"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <!-- Host view: live guest list -->
            <VerticalStackLayout x:Name="hostPanel" IsVisible="False" Spacing="8">

                <Label x:Name="lblNoGuests"
                       Text="Waiting for guests to join…"
                       TextColor="Gray" FontSize="Medium"
                       HorizontalOptions="Center"/>

                <CollectionView x:Name="guestList" SelectionMode="None" MinimumHeightRequest="40">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" Padding="8,10">
                                <Label Grid.Column="0" Text="{Binding Ip}"
                                       FontSize="Medium" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding PingDisplay}"
                                       FontSize="Small" TextColor="Gray" VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

            <!-- Flash button – host only -->
            <Button x:Name="btnFlash" Text="⚡  Flash" Clicked="OnFlashClicked"
                    IsVisible="False" FontSize="Large"
                    BackgroundColor="#F5A623" TextColor="White"
                    WidthRequest="220" HeightRequest="60" CornerRadius="30"/>

        </VerticalStackLayout>

        <Button Grid.Row="1" Text="Leave Room" Clicked="OnLeaveClicked"
                BackgroundColor="#E74C3C" TextColor="White" HeightRequest="50"/>

    </Grid>
</ContentPage>
