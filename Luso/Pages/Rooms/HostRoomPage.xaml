<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Luso.Shared.Components"
             x:Class="Luso.Features.Rooms.Pages.HostRoomPage"
             Shell.NavBarIsVisible="False">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False"
                IsEnabled="False"/>
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="16,48,16,0"
          RowSpacing="12">

        <!-- Room name -->
        <Label x:Name="lblRoomName"
               Grid.Row="0"
               Style="{StaticResource Title2}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"/>

        <!-- Dynamic pad grid -->
        <Grid x:Name="padGrid"
                Grid.Row="1"
                RowSpacing="8"
                ColumnSpacing="8"
              VerticalOptions="Fill"
                HorizontalOptions="Fill"/>

        <!-- Bottom action bar -->
        <components:BottomBarView Grid.Row="2">
            <Grid ColumnDefinitions="*,*,*"
                    ColumnSpacing="8">

                <Button Grid.Column="0"
                        Text="Invite"
                        Clicked="OnInviteToolbarClicked"
                        BackgroundColor="{StaticResource BrandPrimary}"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="46"/>

                <Button Grid.Column="1"
                        Text="Kick"
                        Clicked="OnKickToolbarClicked"
                        BackgroundColor="{StaticResource DarkSurfaceRaised}"
                        TextColor="{StaticResource DarkTextPrimary}"
                        FontSize="14"
                        CornerRadius="10"
                        HeightRequest="46"/>

                <Button Grid.Column="2"
                        Text="Close"
                        Clicked="OnLeaveClicked"
                        BackgroundColor="{StaticResource SemanticDanger}"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="46"/>
            </Grid>
        </components:BottomBarView>
    </Grid>
</ContentPage>
