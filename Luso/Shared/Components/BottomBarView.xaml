<?xml version="1.0" encoding="utf-8" ?>
<!--
    BottomBarView — reusable styled action bar for the bottom of room pages.
    Usage: wrap any button layout as a child; the component supplies the
    elevated surface, top-rounded corners, and safe-area bottom padding.

    <components:BottomBarView>
        <Grid ColumnDefinitions="*,*">
            <Button ... />
            <Button ... />
        </Grid>
    </components:BottomBarView>
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Luso.Shared.Components.BottomBarView">
    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Border BackgroundColor="{StaticResource DarkSurface}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20,20,0,0"
                    Padding="8,10,8,28">
                <ContentPresenter/>
            </Border>
        </ControlTemplate>
    </ContentView.ControlTemplate>
</ContentView>
